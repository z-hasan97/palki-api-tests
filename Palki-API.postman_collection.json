{
  "info": { 
    "name": "Palki Platform API - Complete v0.0.5", 
    "description": "10 microservices, 60+ endpoints, RBAC, Agent-Client, Media", 
    "version": "0.0.4",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" 
  },
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api/v1" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "agentId", "value": "" },
    { "key": "matchId", "value": "" },
    { "key": "postSlug", "value": "" },
    { "key": "mediaId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health (v0.0.5)",
      "item": [
        { "name": "All Services", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] } } }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        { "name": "Register", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"v5test@example.com\",\"password\":\"Test1234\",\"name\":\"v0.0.5 User\"}" }, "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] } } },
        { "name": "Login (Admin)", "event": [{ "listen": "test", "script": { "exec": ["var d=pm.response.json();if(d.accessToken)pm.collectionVariables.set('adminToken',d.accessToken)"], "type": "text/javascript" } }], "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"identifier\":\"admin@palki.com\",\"password\":\"Admin1234\",\"deviceId\":\"postman\"}" }, "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] } } },
        { "name": "Login (User)", "event": [{ "listen": "test", "script": { "exec": ["var d=pm.response.json();if(d.accessToken)pm.collectionVariables.set('token',d.accessToken);if(d.user)pm.collectionVariables.set('userId',d.user.id)"], "type": "text/javascript" } }], "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"identifier\":\"flowtest2@example.com\",\"password\":\"Test1234\",\"deviceId\":\"postman\"}" }, "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] } } }
      ]
    },
    {
      "name": "2. User",
      "item": [
        { "name": "Get Profile", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{token}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/users/profile", "host": ["{{baseUrl}}"], "path": ["users","profile"] } } }
      ]
    },
    {
      "name": "3. Clients",
      "item": [
        { "name": "List Clients (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{adminToken}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/clients", "host": ["{{baseUrl}}"], "path": ["clients"] } } }
      ]
    },
    {
      "name": "4. Agents",
      "item": [
        { "name": "List Agents", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{adminToken}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/agents", "host": ["{{baseUrl}}"], "path": ["agents"] } } },
        { "name": "Agent Clients", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{adminToken}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/agents/b14a5627-9f75-4ff3-9e3b-f31b6ca95638/clients", "host": ["{{baseUrl}}"], "path": ["agents","b14a5627-9f75-4ff3-9e3b-f31b6ca95638","clients"] } } }
      ]
    },
    {
      "name": "5. Payments",
      "item": [
        { "name": "List Packages", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/packages", "host": ["{{baseUrl}}"], "path": ["packages"] } } },
        { "name": "Payment History", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{adminToken}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/payments", "host": ["{{baseUrl}}"], "path": ["payments"] } } }
      ]
    },
    {
      "name": "6. Matches",
      "item": [
        { "name": "List Matches", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{adminToken}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/matches", "host": ["{{baseUrl}}"], "path": ["matches"] } } }
      ]
    },
    {
      "name": "7. Blog",
      "item": [
        { "name": "Public Posts", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/blog/posts", "host": ["{{baseUrl}}"], "path": ["blog","posts"] } } }
      ]
    },
    {
      "name": "8. Media",
      "item": [
        { "name": "List Media", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{adminToken}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/media", "host": ["{{baseUrl}}"], "path": ["media"] } } }
      ]
    },
    {
      "name": "9. Admin",
      "item": [
        { "name": "Dashboard", "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{adminToken}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/admin/dashboard", "host": ["{{baseUrl}}"], "path": ["admin","dashboard"] } } },
        { "name": "RBAC Test (User blocked)", "event": [{ "listen": "test", "script": { "exec": ["pm.test('403 Forbidden', pm.response.code === 403)"], "type": "text/javascript" } }], "request": { "auth": { "type": "bearer", "bearer": [{"key":"token","value":"{{token}}","type":"string"}] }, "method": "GET", "url": { "raw": "{{baseUrl}}/admin/dashboard", "host": ["{{baseUrl}}"], "path": ["admin","dashboard"] } } }
      ]
    },
    {
      "name": "10. Notifications",
      "item": [
        { "name": "Send", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"recipient\":\"demo@test.com\",\"message\":\"v0.0.5 test\",\"channel\":\"email\",\"action\":\"send\"}" }, "url": { "raw": "{{baseUrl}}/notifications/send", "host": ["{{baseUrl}}"], "path": ["notifications","send"] } } }
      ]
    }
  ]
}

