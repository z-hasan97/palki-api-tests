{
  "info": {
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "name": "5. Admin Suite"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1"
    }
  ],
  "item": [
    {
      "name": "5. Admin Suite",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\":\"admin@palki.com\",\"password\":\"Admin1234\",\"deviceId\":\"admin_test\"}"
            }
          }
        },
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "dashboard"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "users"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Reports",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/reports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "reports"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Create Blog Post",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/admin/blog/posts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "blog",
                "posts"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Admin Demo Post\",\"content\":\"Posted from admin suite\",\"status\":\"PUBLISHED\",\"action\":\"create\"}"
            }
          }
        }
      ]
    }
  ]
}