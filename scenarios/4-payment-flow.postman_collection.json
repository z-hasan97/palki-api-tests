{
  "info": {
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "name": "4. Payment Flow"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1"
    }
  ],
  "item": [
    {
      "name": "4. Payment Flow",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\":\"flowtest2@example.com\",\"password\":\"Test1234\",\"deviceId\":\"pay_test\"}"
            }
          }
        },
        {
          "name": "Packages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/packages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "packages"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Initiate",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/payments/initiate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "initiate"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\":\"669ff023-485e-4287-b154-16a92ab0f64f\",\"packageId\":\"f3555008-f5c1-4240-95e3-6dcf18d8f113\",\"amount\":999}"
            }
          }
        },
        {
          "name": "Verify",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/payments/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "verify"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"paymentId\":\"{{paymentId}}\",\"transactionId\":\"txn_demo\"}"
            }
          }
        },
        {
          "name": "History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Clients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clients",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clients"
              ]
            },
            "header": []
          }
        }
      ]
    }
  ]
}