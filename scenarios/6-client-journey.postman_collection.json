{
  "info": {
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "name": "6. Client Journey"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1"
    }
  ],
  "item": [
    {
      "name": "6. Client Journey",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"clientdemo@test.com\",\"password\":\"Test1234\",\"name\":\"Client Demo\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\":\"clientdemo@test.com\",\"password\":\"Test1234\",\"deviceId\":\"journey\"}"
            }
          }
        },
        {
          "name": "Packages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/packages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "packages"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "profile"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "profile"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Client Updated\"}"
            }
          }
        },
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/payments/initiate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "initiate"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\":\"{{userId}}\",\"packageId\":\"f3555008-f5c1-4240-95e3-6dcf18d8f113\",\"amount\":999}"
            }
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/payments/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "verify"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"paymentId\":\"{{paymentId}}\",\"transactionId\":\"txn_journey\"}"
            }
          }
        },
        {
          "name": "Clients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clients",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clients"
              ]
            },
            "header": []
          }
        },
        {
          "name": "Request Match",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/matches/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches",
                "request"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"requesterId\":\"{{userId}}\",\"targetId\":\"14b5a018-239a-4e16-bb1f-3ff13ff790c9\",\"action\":\"request\"}"
            }
          }
        }
      ]
    }
  ]
}